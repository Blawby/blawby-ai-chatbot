# Local development environment variables (Worker secrets only)
# Keep secrets here; non-sensitive configuration lives in wrangler.toml.
# For production secrets, use: wrangler secret put <KEY_NAME>
# Copy this file to worker/.dev.vars (single source of truth).
# Durable Object bindings (CHAT_ROOM, MATTER_PROGRESS) are configured in worker/wrangler.toml.

# Required for local Worker development; must match VITE_BACKEND_API_URL when set
BACKEND_API_URL=your_backend_api_url_here

# AI model (Workers AI)
# The Worker calls the Workers AI OpenAI-compatible endpoint directly (not AI
# Gateway). AI_MODEL must be a Workers AI model ID (`@cf/...`). Optional — falls
# back to the Worker's DEFAULT_AI_MODEL when unset.
AI_MODEL=@cf/zai-org/glm-4.7-flash

# API Keys and Tokens (SENSITIVE)
CLOUDFLARE_API_TOKEN=your_cloudflare_api_token_here
# Cloudflare API token with Workers AI access — the bearer token for chat
# completions. Legacy CF_AIG_ name retained; the Worker does not use AI Gateway.
CF_AIG_TOKEN=your_cloudflare_workers_ai_token_here
ONESIGNAL_APP_ID=your_onesignal_app_id_here
ONESIGNAL_REST_API_KEY=your_onesignal_rest_api_key_here
GEOAPIFY_API_KEY=your_geoapify_api_key_here
GEOAPIFY_DAILY_LIMIT=1000
GEOAPIFY_RPM_PER_IP=60
GEOAPIFY_MIN_CHARS=3

# Account IDs (SENSITIVE)
CLOUDFLARE_ACCOUNT_ID=your_cloudflare_account_id_here

# Adobe PDF Services API Configuration (SENSITIVE)
ADOBE_CLIENT_ID=your_adobe_client_id_here
ADOBE_CLIENT_SECRET=your_adobe_client_secret_here
ADOBE_TECHNICAL_ACCOUNT_ID=your_technical_account_id@techacct.adobe.com
ADOBE_TECHNICAL_ACCOUNT_EMAIL=your_technical_account_email@techacct.adobe.com
ADOBE_ORGANIZATION_ID=your_organization_id@AdobeOrg
