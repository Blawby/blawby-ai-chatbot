{
	"extends": "./tsconfig.base.json",
	"compilerOptions": {
		"lib": ["ES2022", "DOM", "DOM.Iterable"]
	},
	"include": [
		"node_modules/vite/client.d.ts",
		"src"
	],
	"exclude": [
		"src/**/__tests__/**",
		"src/**/*.test.ts",
		"src/**/*.test.tsx",
		"src/**/*.spec.ts",
		"src/**/*.spec.tsx",
		"**/*.stories.ts",
		"**/*.stories.tsx"
	]
}
